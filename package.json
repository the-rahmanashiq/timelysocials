{
  "name": "timely-socials",
  "version": "1.0.0",
  "private": true,
  "description": "Unified Timely Socials app with a Next.js frontend and Express API in one root workspace.",
  "main": "dest/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "next dev",
    "dev:api": "ts-node-dev --project tsconfig.server.json --respawn --transpile-only src/server.ts",
    "build": "npm run build:web && npm run build:api",
    "build:web": "next build",
    "build:api": "rimraf dest && tsc -p tsconfig.server.json",
    "start": "concurrently \"npm run start:web\" \"npm run start:api\"",
    "start:web": "next start",
    "start:api": "node dest/server.js",
    "lint": "next lint",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@reduxjs/toolkit": "^2.8.2",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "dropzone": "^6.0.0-beta.2",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "luxon": "^3.7.1",
    "mongoose": "^8.16.3",
    "motion": "^12.18.1",
    "multer": "^2.0.2",
    "next": "15.3.8",
    "node-cron": "^4.2.1",
    "nouislider": "^15.8.1",
    "oauth-1.0a": "^2.2.6",
    "preline": "^3.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.59.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "vanilla-calendar-pro": "^3.0.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.0",
    "@types/node": "^24.1.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
